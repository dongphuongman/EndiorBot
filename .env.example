# EndiorBot Environment Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# State & Configuration
# ═══════════════════════════════════════════════════════════════════

# State directory (default: ~/.endiorbot/)
# ENDIORBOT_STATE_DIR=~/.endiorbot/

# Config file path (default: .sdlc-config.json)
# ENDIORBOT_CONFIG_PATH=.sdlc-config.json

# Active profile
# ENDIORBOT_PROFILE=default

# ═══════════════════════════════════════════════════════════════════
# AI Provider API Keys (stored in OS Keychain, but can override here)
# ═══════════════════════════════════════════════════════════════════

# Anthropic (Claude) - Primary model
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (GPT) - Expert model
# OPENAI_API_KEY=sk-xxx

# Google AI (Gemini) - Expert model
# GOOGLE_AI_KEY=xxx

# Mistral - Expert model
# MISTRAL_API_KEY=xxx

# ═══════════════════════════════════════════════════════════════════
# Gateway Configuration
# ═══════════════════════════════════════════════════════════════════

# Gateway port (default: 3030)
# ENDIORBOT_GATEWAY_PORT=3030

# Gateway auth token (auto-generated if not set)
# ENDIORBOT_GATEWAY_TOKEN=

# ═══════════════════════════════════════════════════════════════════
# Debug & Development
# ═══════════════════════════════════════════════════════════════════

# Enable debug logging
# ENDIORBOT_DEBUG=true

# Skip telemetry
# ENDIORBOT_SKIP_TELEMETRY=true

# ═══════════════════════════════════════════════════════════════════
# Legacy Support (OpenClaw compatibility)
# ═══════════════════════════════════════════════════════════════════

# These are read for backward compatibility during migration
# OPENCLAW_STATE_DIR=~/.openclaw/
# OPENCLAW_CONFIG_PATH=openclaw.json
