# EndiorBot Environment Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# State & Configuration
# ═══════════════════════════════════════════════════════════════════

# State directory (default: ~/.endiorbot/)
# ENDIORBOT_STATE_DIR=~/.endiorbot/

# Config file path (default: .sdlc-config.json)
# ENDIORBOT_CONFIG_PATH=.sdlc-config.json

# Active profile
# ENDIORBOT_PROFILE=default

# ═══════════════════════════════════════════════════════════════════
# AI Provider API Keys
# Note: CEO uses subscription for Claude/OpenAI/Gemini chat
# API keys below are for programmatic automation only
# ═══════════════════════════════════════════════════════════════════

# Anthropic (Claude) - Only needed for Agent SDK automation
# CEO uses Claude Code Max subscription, no API key needed for interactive use
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_TEAM_DEV_API_KEY=sk-ant-xxx
# ANTHROPIC_PRIMARY_QUOTA=50
# ANTHROPIC_TEAM_DEV_QUOTA=50

# OpenAI (GPT) - Service account for automation
OPENAI_API_KEY=sk-svcacct-xxx

# Google AI (Gemini) - For automation
GEMINI_API_KEY=AIzaSy-xxx

# Ollama — Local or remote Ollama API key
OLLAMA_API_KEY=aip_xxx_production_2026_xxx

# Ollama local URL (Sprint 134 H2)
# Priority: OLLAMA_URL > OLLAMA_HOST > OLLAMA_BASE_URL > http://localhost:11434
# OLLAMA_URL=http://localhost:11434

# Ollama Remote (optional — your own Ollama server, e.g. ai.nqh-internal.example)
OLLAMA_REMOTE_URL=https://ollama.example.com
OLLAMA_REMOTE_API_KEY=aip_xxx_production_2026_xxx
OLLAMA_REMOTE_MODEL=qwen3-coder:30b

# MTClaw MCP Gateway (Sprint 113 — Cross-System Agent Communication)
MTCLAW_API_KEY=your-mtclaw-api-key-here

# ═══════════════════════════════════════════════════════════════════
# Notifications
# ═══════════════════════════════════════════════════════════════════

# Telegram bot token for CEO notifications
TELEGRAM_BOT_TOKEN=xxx:xxx

# ═══════════════════════════════════════════════════════════════════
# GitHub
# ═══════════════════════════════════════════════════════════════════

# Personal Access Token
GITHUB_PAT=github_pat_xxx

# ═══════════════════════════════════════════════════════════════════
# Resource Router (Sprint 38)
# ═══════════════════════════════════════════════════════════════════

# Provider timeout in ms (default: 30000)
PROVIDER_TIMEOUT_MS=30000

# Max parallel queries for multi-model (default: 3)
MAX_PARALLEL_QUERIES=3

# Enable multi-model consultation (default: true)
ENABLE_MULTI_MODEL=true

# Account manager notifications per hour (default: 4)
ACCOUNT_MANAGER_MAX_NOTIFICATIONS=4

# ═══════════════════════════════════════════════════════════════════
# Gateway Configuration
# ═══════════════════════════════════════════════════════════════════

# Gateway port (default: 18790)
# ENDIORBOT_GATEWAY_PORT=18790

# Gateway host binding (Sprint 134 H4). Set 0.0.0.0 for production/remote access
# ENDIORBOT_GATEWAY_HOST=127.0.0.1

# OAuth callback URL (Sprint 134 H1)
# ENDIORBOT_OAUTH_CALLBACK_URL=http://localhost:18790/oauth/callback

# Gateway auth token (auto-generated if not set)
# ENDIORBOT_GATEWAY_TOKEN=

# ═══════════════════════════════════════════════════════════════════
# Timeouts (Sprint 134 T2 — SSOT at src/config/timeouts.ts)
# ═══════════════════════════════════════════════════════════════════

# Per-model API call timeout (default: 30s)
# ENDIORBOT_MODEL_TIMEOUT_MS=30000

# Total chat handler timeout (default: 60s)
# ENDIORBOT_CHAT_TIMEOUT_MS=60000

# MCP agent chat timeout (default: 130s)
# MTCLAW_TIMEOUT_MS=130000

# MCP tool call timeout (default: 30s)
# MTCLAW_DEFAULT_TIMEOUT_MS=30000

# OpenAI provider timeout (default: 30s)
# ENDIORBOT_OPENAI_TIMEOUT_MS=30000

# Claude Code CLI timeout (default: 300s / 5min)
# ENDIORBOT_CLAUDE_TIMEOUT_MS=300000

# RL session idle timeout (default: 30min)
# ENDIORBOT_SESSION_IDLE_TIMEOUT_MS=1800000

# RL feedback window (default: 2h)
# ENDIORBOT_FEEDBACK_WINDOW_MS=7200000

# ═══════════════════════════════════════════════════════════════════
# Channel Polling (Sprint 134 T3)
# ═══════════════════════════════════════════════════════════════════

# Telegram polling interval (default: 3s)
# ENDIORBOT_TELEGRAM_POLLING_MS=3000

# Zalo polling interval (default: 5s)
# ENDIORBOT_ZALO_POLLING_MS=5000

# Webhook max body size (default: 1MB)
# ENDIORBOT_WEBHOOK_MAX_BODY_SIZE=1048576

# Rate limit cleanup interval (default: 60s)
# ENDIORBOT_RATE_LIMIT_CLEANUP_MS=60000

# Audit log max size before rotation (default: 10MB)
# ENDIORBOT_AUDIT_MAX_LOG_SIZE=10485760

# ═══════════════════════════════════════════════════════════════════
# C2 Webhooks Ingress (Sprint 134 T4)
# ═══════════════════════════════════════════════════════════════════

# Shared secret for webhook auth (REQUIRED to enable webhooks — fail-closed without it)
# ENDIORBOT_WEBHOOK_SECRET=your-secret-here

# Webhook rate limit per trigger per minute (default: 10)
# ENDIORBOT_WEBHOOK_RATE_LIMIT=10

# ═══════════════════════════════════════════════════════════════════
# Active Memory (Sprint 133 S1)
# ═══════════════════════════════════════════════════════════════════

# Kill switch — CEO only (default: false)
# ENDIORBOT_FF_ACTIVE_MEMORY_ENABLED=false

# ═══════════════════════════════════════════════════════════════════
# Debug & Development
# ═══════════════════════════════════════════════════════════════════

# Enable debug logging
# ENDIORBOT_DEBUG=true

# Skip telemetry
# ENDIORBOT_SKIP_TELEMETRY=true

# ═══════════════════════════════════════════════════════════════════
# Sprint 131: Agent Orchestration (Multica ADOPT + Sau Sheong cherry-picks)
# ═══════════════════════════════════════════════════════════════════

# Auto-handoff opt-in (ADR-046-STUB): skip the CEO approval prompt and
# dispatch handoffs automatically. DEFAULT is CEO approval — only set this
# if you trust the specific workflow. Destructive actions (PATCH mode)
# still pass through existing gates regardless.
# ENDIORBOT_AUTO_HANDOFF=true

# Knowledge erosion check opt-out (Sprint 131): disables the post-response
# understanding prompt shown after substantive AI responses in chat mode.
# Prototype only — no persistence, no analytics.
# ENDIORBOT_SKIP_REVIEW_PROMPT=true

# ═══════════════════════════════════════════════════════════════════
# Legacy Support (OpenClaw compatibility)
# ═══════════════════════════════════════════════════════════════════

# These are read for backward compatibility during migration
# OPENCLAW_STATE_DIR=~/.openclaw/
# OPENCLAW_CONFIG_PATH=openclaw.json
