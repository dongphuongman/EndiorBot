# EndiorBot Environment Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# State & Configuration
# ═══════════════════════════════════════════════════════════════════

# State directory (default: ~/.endiorbot/)
# ENDIORBOT_STATE_DIR=~/.endiorbot/

# Config file path (default: .sdlc-config.json)
# ENDIORBOT_CONFIG_PATH=.sdlc-config.json

# Active profile
# ENDIORBOT_PROFILE=default

# ═══════════════════════════════════════════════════════════════════
# AI Provider API Keys
# Note: CEO uses subscription for Claude/OpenAI/Gemini chat
# API keys below are for programmatic automation only
# ═══════════════════════════════════════════════════════════════════

# Anthropic (Claude) - Only needed for Agent SDK automation
# CEO uses Claude Code Max subscription, no API key needed for interactive use
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_TEAM_DEV_API_KEY=sk-ant-xxx
# ANTHROPIC_PRIMARY_QUOTA=50
# ANTHROPIC_TEAM_DEV_QUOTA=50

# OpenAI (GPT) - Service account for automation
OPENAI_API_KEY=sk-svcacct-xxx

# Google AI (Gemini) - For automation
GEMINI_API_KEY=AIzaSy-xxx

# Ollama - NQH AI-Platform production key
OLLAMA_API_KEY=aip_xxx_production_2026_xxx

# Ollama Remote (NQH AI-Platform)
OLLAMA_REMOTE_URL=https://ai.nqh-internal.example
OLLAMA_REMOTE_API_KEY=aip_xxx_production_2026_xxx
OLLAMA_REMOTE_MODEL=qwen3-coder:30b

# MTClaw MCP Gateway (Sprint 113 — Cross-System Agent Communication)
MTCLAW_API_KEY=your-mtclaw-api-key-here

# ═══════════════════════════════════════════════════════════════════
# Notifications
# ═══════════════════════════════════════════════════════════════════

# Telegram bot token for CEO notifications
TELEGRAM_BOT_TOKEN=xxx:xxx

# ═══════════════════════════════════════════════════════════════════
# GitHub
# ═══════════════════════════════════════════════════════════════════

# Personal Access Token
GITHUB_PAT=github_pat_xxx

# ═══════════════════════════════════════════════════════════════════
# Resource Router (Sprint 38)
# ═══════════════════════════════════════════════════════════════════

# Provider timeout in ms (default: 30000)
PROVIDER_TIMEOUT_MS=30000

# Max parallel queries for multi-model (default: 3)
MAX_PARALLEL_QUERIES=3

# Enable multi-model consultation (default: true)
ENABLE_MULTI_MODEL=true

# Account manager notifications per hour (default: 4)
ACCOUNT_MANAGER_MAX_NOTIFICATIONS=4

# ═══════════════════════════════════════════════════════════════════
# Gateway Configuration
# ═══════════════════════════════════════════════════════════════════

# Gateway port (default: 3030)
# ENDIORBOT_GATEWAY_PORT=3030

# Gateway auth token (auto-generated if not set)
# ENDIORBOT_GATEWAY_TOKEN=

# ═══════════════════════════════════════════════════════════════════
# Debug & Development
# ═══════════════════════════════════════════════════════════════════

# Enable debug logging
# ENDIORBOT_DEBUG=true

# Skip telemetry
# ENDIORBOT_SKIP_TELEMETRY=true

# ═══════════════════════════════════════════════════════════════════
# Legacy Support (OpenClaw compatibility)
# ═══════════════════════════════════════════════════════════════════

# These are read for backward compatibility during migration
# OPENCLAW_STATE_DIR=~/.openclaw/
# OPENCLAW_CONFIG_PATH=openclaw.json
