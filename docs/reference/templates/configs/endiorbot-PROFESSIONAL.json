{
  "$schema": "https://endiorbot.ai/schemas/config.json",
  "meta": {
    "template": "PROFESSIONAL",
    "version": "1.1.0",
    "description": "SDLC Framework 6.3.1 - PROFESSIONAL tier (12 agents, 5 teams)"
  },
  "agents": {
    "defaults": {
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "1h"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "assistant",
        "role": "assistant",
        "default": true,
        "description": "Router - message routing and delegation"
      },
      {
        "id": "researcher",
        "role": "researcher",
        "description": "SE4A - Stage 00 Discovery and user research"
      },
      {
        "id": "pm",
        "role": "pm",
        "description": "SE4A - Stage 00-01 Requirements and user stories"
      },
      {
        "id": "pjm",
        "role": "pjm",
        "description": "SE4A - Sprint coordination and task tracking"
      },
      {
        "id": "architect",
        "role": "architect",
        "description": "SE4A - Stage 02 System design and ADRs"
      },
      {
        "id": "coder",
        "role": "coder",
        "description": "SE4A - Stage 04 Implementation and TDD"
      },
      {
        "id": "reviewer",
        "role": "reviewer",
        "description": "SE4A - Stage 04-05 Code review and standards"
      },
      {
        "id": "tester",
        "role": "tester",
        "description": "SE4A - Stage 05 Testing and quality assurance"
      },
      {
        "id": "ceo",
        "role": "ceo",
        "description": "SE4H - Strategic direction and executive review (advisor only)"
      },
      {
        "id": "cpo",
        "role": "cpo",
        "description": "SE4H - Product advisor, approves G0.1 and G1"
      },
      {
        "id": "cto",
        "role": "cto",
        "description": "SE4H - Technical advisor, approves G2 and G3"
      },
      {
        "id": "cso",
        "role": "cso",
        "description": "SE4H - Security advisor, approves G2/G3/G4 security checklists (PRO+)"
      }
    ]
  },
  "sdlc": {
    "enabled": true,
    "tier": "PROFESSIONAL",
    "teams": {
      "planning": {
        "archetype": "planning",
        "leader": "pm",
        "members": ["researcher", "pm", "pjm", "architect"]
      },
      "design": {
        "archetype": "design",
        "leader": "architect",
        "members": ["architect", "pm", "coder", "cso"]
      },
      "dev": {
        "archetype": "dev",
        "leader": "coder",
        "members": ["coder", "reviewer"]
      },
      "qa": {
        "archetype": "qa",
        "leader": "tester",
        "members": ["tester", "reviewer", "cso"]
      },
      "executive": {
        "archetype": "executive",
        "leader": "cto",
        "members": ["cpo", "cto", "cso"]
      }
    },
    "gates": {
      "required": ["G0.1", "G1", "G2", "G-Sprint", "G3", "G-Sprint-Close"],
      "approvers": {
        "G0.1": ["cpo"],
        "G1": ["cpo"],
        "G2": ["cto", "cso"],
        "G3": ["cto", "cso"],
        "G-Sprint": ["pjm"],
        "G-Sprint-Close": ["pjm"]
      }
    },
    "workflow": {
      "maxReviewCycles": 3,
      "escalationThreshold": 3,
      "approvalRequired": true
    }
  }
}
