{
  "$schema": "https://endiorbot.ai/schemas/config.json",
  "meta": {
    "template": "LITE",
    "version": "1.1.0",
    "description": "SDLC Framework 6.3.0 - LITE tier (2 agents, minimal workflow)"
  },
  "agents": {
    "defaults": {
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "30m"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      }
    },
    "list": [
      {
        "id": "assistant",
        "role": "assistant",
        "default": true,
        "description": "Router - message routing"
      },
      {
        "id": "fullstack",
        "role": "fullstack",
        "description": "SE4A - Full-stack development (all SDLC stages)"
      }
    ]
  },
  "sdlc": {
    "enabled": true,
    "tier": "LITE",
    "teams": {
      "fullstack": {
        "archetype": "fullstack",
        "leader": "fullstack",
        "members": ["fullstack"]
      }
    },
    "gates": {
      "required": [],
      "approvers": {}
    },
    "workflow": {
      "maxReviewCycles": 0,
      "escalationThreshold": 1,
      "approvalRequired": false
    }
  }
}
