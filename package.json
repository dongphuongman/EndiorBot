{
  "name": "endiorbot",
  "version": "0.1.0-beta.3",
  "description": "Solo developer tool for enterprise-scale projects: Claude Code + SDLC framework automation + Multi-model orchestrator (beta)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "endiorbot": "endiorbot.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:security": "vitest run src/security --reporter=verbose",
    "test:quality": "vitest run src/agents/quality --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint:souls": "tsx scripts/lint-souls.ts",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Minh-Tam-Solution/EndiorBot.git"
  },
  "homepage": "https://github.com/Minh-Tam-Solution/EndiorBot",
  "bugs": {
    "url": "https://github.com/Minh-Tam-Solution/EndiorBot/issues"
  },
  "keywords": [
    "sdlc",
    "claude",
    "multi-model",
    "orchestrator",
    "automation",
    "solo-developer",
    "enterprise",
    "ai-assistant"
  ],
  "author": "Minh-Tam-Solution",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "endiorbot.mjs",
    ".env.example",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.35.0",
    "@composio/core": "0.6.3",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "json5": "^2.2.3",
    "keytar": "^7.9.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "keytar"
    ],
    "overrides": {
      "flatted": ">=3.4.2",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "esbuild@<0.25.0": "0.25.0",
      "tar@<=7.5.10": "7.5.11",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@<2.0.2": "2.0.2",
      "lodash@<4.17.21": "4.17.21",
      "lodash@>=4.17.21 <4.18.1": "4.18.1",
      "xmldom@>=0.0.0 <0.9.8": "0.9.8",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "electron@>=40.0.0-alpha.1 <40.7.0": ">=40.7.0",
      "electron@>=40.0.0-alpha.1 <40.8.0": ">=40.8.0",
      "electron@>=40.0.0-alpha.1 <40.8.1": ">=40.8.1",
      "electron@>=40.0.0-alpha.1 <40.8.4": ">=40.8.4",
      "electron@>=40.0.0-alpha.1 <40.8.3": ">=40.8.3",
      "electron@>=40.0.0-alpha.1 <40.8.5": ">=40.8.5",
      "@xmldom/xmldom@<0.8.13": ">=0.8.13",
      "postcss@<8.5.10": ">=8.5.10",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "vite@>=6.0.0 <6.4.2": ">=6.4.2"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
